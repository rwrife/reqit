{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HTTP",
  "scopeName": "source.http",
  "patterns": [
    { "include": "#separator" },
    { "include": "#comment" },
    { "include": "#requestLine" },
    { "include": "#header" },
    { "include": "#variable" }
  ],
  "repository": {
    "separator": {
      "match": "^###.*$",
      "name": "comment.line.separator.http"
    },
    "comment": {
      "match": "^\\s*(#|//).*$",
      "name": "comment.line.http"
    },
    "requestLine": {
      "match": "^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|TRACE)\\s+(\\S+)(?:\\s+(HTTP/\\S+))?\\s*$",
      "captures": {
        "1": { "name": "keyword.control.http" },
        "2": { "name": "string.unquoted.url.http" },
        "3": { "name": "constant.language.http" }
      }
    },
    "header": {
      "match": "^([A-Za-z0-9-]+)\\s*:\\s*(.*)$",
      "captures": {
        "1": { "name": "support.type.header.http" },
        "2": { "name": "string.unquoted.header-value.http" }
      }
    },
    "variable": {
      "match": "\\{\\{[^}]+\\}\\}",
      "name": "variable.other.http"
    }
  }
}
