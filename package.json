{
  "name": "reqit",
  "displayName": "Reqit",
  "description": "Test it before you req it! Test REST APIs from VS Code with first-class auth (mTLS, JWT, OAuth2). Local-only. No telemetry.",
  "version": "0.0.1",
  "publisher": "rwrife",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rwrife/reqit.git"
  },
  "categories": ["Other", "Testing"],
  "activationEvents": [
    "onLanguage:http",
    "onCommand:reqit.initWorkspace",
    "workspaceContains:.requests",
    "workspaceContains:.requests/**/*.http"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "http",
        "aliases": ["HTTP", "http"],
        "extensions": [".http", ".rest"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "http",
        "scopeName": "source.http",
        "path": "./syntaxes/http.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "reqit.initWorkspace",
        "title": "Reqit: Init Workspace",
        "category": "Reqit"
      },
      {
        "command": "reqit.sendRequest",
        "title": "Reqit: Send Request",
        "category": "Reqit"
      },
      {
        "command": "reqit.refreshRequests",
        "title": "Reqit: Refresh Requests",
        "category": "Reqit",
        "icon": "$(refresh)"
      },
      {
        "command": "reqit.selectEnv",
        "title": "Reqit: Select Environment",
        "category": "Reqit"
      },
      {
        "command": "reqit.setSecret",
        "title": "Reqit: Set Secret",
        "category": "Reqit"
      },
      {
        "command": "reqit.copyAsCurl",
        "title": "Reqit: Copy as curl",
        "category": "Reqit"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reqit",
          "title": "Reqit",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "reqit": [
        {
          "id": "reqit.requests",
          "name": "Requests",
          "icon": "$(symbol-event)",
          "contextualTitle": "Reqit Requests"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "reqit.refreshRequests",
          "when": "view == reqit.requests",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node ./esbuild.mjs",
    "watch": "node ./esbuild.mjs --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "undici": "^6.19.0",
    "zod": "^3.23.0"
  }
}
